# =============================================
# REQUIRED for hosting (Supabase + Vercel)
# =============================================

# From Supabase → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# From Supabase → Project Settings → API → "service_role" key (SECRET - never expose to client)
# Click "API settings" link under the keys to find it
SUPABASE_SERVICE_ROLE_KEY=eyJhbG...your_service_role_key

# Your live URL (for SEO metadata, sitemap, etc.)
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# Fallback admin (used when admin_config table in Supabase is empty)
NEXT_PUBLIC_ADMIN_EMAIL=admin@pariksha.local
NEXT_PUBLIC_ADMIN_PASSWORD=YourSecurePassword

# =============================================
# OPTIONAL - Add later for email OTP & notifications
# =============================================

# From Brevo → Settings → SMTP & API → API Keys
# BREVO_API_KEY=xkeysib-xxx
# BREVO_FROM_EMAIL=noreply@yourdomain.com
# BREVO_FROM_NAME=Pariksha Samachar
